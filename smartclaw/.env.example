# SmartClaw Environment Variables
# Copy this file to .env and fill in your values.

# Configuration file path (default: config/config.yaml)
SMARTCLAW_CONFIG_PATH=config/config.yaml

# Logging overrides
SMARTCLAW_LOG_LEVEL=INFO
SMARTCLAW_LOG_FORMAT=console
# SMARTCLAW_LOG_FILE=logs/smartclaw.log

# ============================================================
# API Keys — set at least ONE of the following
# ============================================================

# Kimi 2.5 (default model) — get key from https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here

# OpenAI (fallback) — get key from https://platform.openai.com/
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (fallback) — get key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tavily Web Search — get key from https://tavily.com/
# TAVILY_API_KEY=tvly-your-key-here
